    private async Task HandleUserPhotoUpload(InputFileChangeEventArgs e)
    {
        if (!AuthService.IsAuthenticated)
        {
            errorMsg = "请先登录后再上传图片。";
            return;
        }

        var files = e.GetMultipleFiles();
        if (files.Count == 0) return;

        isPhotoUploading = true;
        errorMsg = null;
        successMsg = null;
        try
        {
            foreach (var file in files)
            {
                var uploaded = await PostService.UploadMediaWithIdAsync(file);
                await ResourceService.AddResourcePhotoAsync(Id, uploaded.Id);
            }

            await LoadResourcePhotosAsync();
            BuildImageGallery();
            successMsg = "图片上传成功。";
        }
        catch (Exception ex)
        {
            errorMsg = $"上传失败: {ex.Message}";
        }
        finally
        {
            isPhotoUploading = false;
        }
    }

