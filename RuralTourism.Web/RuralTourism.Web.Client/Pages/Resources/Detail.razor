    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading
            && !notFound
            && baseResource != null
            && baseResource.Latitude != 0
            && (!mapInitialized || mapInitializedResourceId != baseResource.Id))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initBaiduMap", "baiduMap", baseResource.Latitude, baseResource.Longitude, baseResource.Name);
                mapInitialized = true;
                mapInitializedResourceId = baseResource.Id;
            }
            catch { }
        }

        if (!string.IsNullOrWhiteSpace(errorMsg) || !string.IsNullOrWhiteSpace(successMsg))
        {
            var currentKey = $"{errorMsg}||{successMsg}";
            if (currentKey != lastAlertKey)
            {
                lastAlertKey = currentKey;
                StartAlertAutoClose();
            }
        }
        else
        {
            lastAlertKey = null;
        }
    }

    private void StartAlertAutoClose()
    {
        alertAutoCloseCts?.Cancel();
        alertAutoCloseCts?.Dispose();
        alertAutoCloseCts = new CancellationTokenSource();
        _ = AutoCloseAlertAsync(alertAutoCloseCts.Token);
    }

    private async Task AutoCloseAlertAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(5000, token);
            errorMsg = null;
            successMsg = null;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
        }
    }

    public void Dispose()
    {
        alertAutoCloseCts?.Cancel();
        alertAutoCloseCts?.Dispose();
    }

    private async Task LoadData()
    {
        isLoading = true;
        notFound = false;
        mapInitialized = false;
        try
        {
            if (Type == "attractions")
            {
                attraction = await ResourceService.GetAttractionAsync(Id);
                if (attraction != null) baseResource = attraction; else notFound = true;
            }
            else if (Type == "accommodations")
            {
                accommodation = await ResourceService.GetAccommodationAsync(Id);
                if (accommodation != null) baseResource = accommodation; else notFound = true;
            }
            else if (Type == "dining")
            {
                dining = await ResourceService.GetDiningDetailAsync(Id);
                if (dining != null) baseResource = dining; else notFound = true;
            }
            else if (Type == "folk")
            {
                folkActivity = await ResourceService.GetFolkActivityAsync(Id);
                if (folkActivity != null) baseResource = folkActivity; else notFound = true;
            }
            else if (Type == "beautiful-villages")
            {
                beautifulVillage = await ResourceService.GetBeautifulVillageAsync(Id);
                if (beautifulVillage != null) baseResource = beautifulVillage; else notFound = true;
            }
            else
            {
                notFound = true;
            }

            if (!notFound)
            {
                await LoadResourcePhotosAsync();
                await LoadResourceReviewsAsync();
                BuildImageGallery();
                InitializeEditModels();
                await LoadSidebarDataAsync();

                if (AuthService.IsAuthenticated)
                {
                    try
                    {
                        await ResourceService.TrackResourceInteractionAsync(Id, "View", $"detail:{Type}");
                    }
                    catch
                    {
                    }
                }
            }
        }
        catch
        {
            notFound = true;
        }
        finally
        {
            isLoading = false;
        }
    }

