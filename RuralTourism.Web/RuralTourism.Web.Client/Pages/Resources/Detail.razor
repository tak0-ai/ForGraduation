    private async Task SaveJoinPlanAsync()
    {
        isJoinPlanSubmitting = true;
        errorMsg = null;
        successMsg = null;
        var spot = string.IsNullOrWhiteSpace(baseResource.Address) ? baseResource.Name : $"{baseResource.Name}（{baseResource.Address}）";

        try
        {
            if (joinPlanMode == "new")
            {
                if (string.IsNullOrWhiteSpace(newPlanTitle))
                {
                    errorMsg = "请填写行程名称。";
                    return;
                }

                var created = await TourPlanService.CreateAsync(new TourPlanUpsertDto
                {
                    Title = newPlanTitle.Trim(),
                    StartAddress = spot,
                    Waypoints = [],
                    RouteMode = "driving",
                    ReturnToStart = false
                });

                if (created == null)
                {
                    errorMsg = "创建行程失败。";
                    return;
                }
            }
            else
            {
                var plan = myTourPlans.FirstOrDefault(x => x.Id == selectedPlanId);
                if (plan == null)
                {
                    errorMsg = "请选择要加入的行程。";
                    return;
                }

                var waypoints = plan.Waypoints?.ToList() ?? [];
                if (!waypoints.Contains(spot, StringComparer.OrdinalIgnoreCase))
                {
                    waypoints.Add(spot);
                }

                var updated = await TourPlanService.UpdateAsync(plan.Id, new TourPlanUpsertDto
                {
                    Title = plan.Title,
                    StartAddress = string.IsNullOrWhiteSpace(plan.StartAddress) ? spot : plan.StartAddress,
                    Waypoints = waypoints,
                    RouteMode = "driving",
                    ReturnToStart = plan.ReturnToStart
                });

                if (updated == null)
                {
                    errorMsg = "加入现有行程失败。";
                    return;
                }
            }

            successMsg = "已加入行程。";
            showJoinPlanPanel = false;
        }
        catch (Exception ex)
        {
            errorMsg = $"加入行程失败: {ex.Message}";
        }
        finally
        {
            isJoinPlanSubmitting = false;
        }
    }

