@code {
    [Parameter]
    public string Type { get; set; } = null!;
    [Parameter]
    public string Id { get; set; } = null!;

    private bool isLoading = true;
    private bool notFound = false;
    private bool isDeleting = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string? errorMsg = null;
    private string? successMsg = null;

    private ResourceDto baseResource = new();
    private AttractionDto? attraction;
    private AccommodationDto? accommodation;
    private DiningDto? dining;
    private FolkActivityDto? folkActivity;
    private BeautifulVillageDto? beautifulVillage;
    private readonly List<string> imageUrls = [];
    private readonly List<AttractionDto> nearbyAttractions = [];
    private readonly List<AccommodationDto> nearbyAccommodations = [];
    private readonly List<DiningDto> nearbyDining = [];
    private readonly List<BeautifulVillageDto> nearbyBeautifulVillages = [];
    private readonly List<AttractionDto> villageAttractions = [];
    private readonly List<AccommodationDto> villageAccommodations = [];
    private readonly List<DiningDto> villageDining = [];
    private readonly List<FolkActivityDto> villageFolkActivities = [];
    private readonly List<ResourcePhotoDto> resourcePhotos = [];
    private readonly List<ResourceReviewDto> resourceReviews = [];
    private int currentImageIndex = 0;
    private int reviewCount = 0;
    private int reviewFilter = 0;
    private string reviewSort = "latest";
    private bool isGalleryOpen = false;
    private bool isPhotoUploading = false;
    private bool isEditCoverUploading = false;
    private bool isSubmittingReview = false;
    private int nearbyRadiusKm = 20;
    private string? lastAlertKey;
    private CancellationTokenSource? alertAutoCloseCts;
    private bool showJoinPlanPanel = false;
    private bool isJoinPlanSubmitting = false;
    private bool showShareResourcePanel = false;
    private bool isLoadingShareRooms = false;
    private bool isSharingResource = false;
    private string? currentUserId;
    private string? selectedShareRoomId;
    private string? shareResourceMessage;
    private string joinPlanMode = "new";
    private string? selectedPlanId;
    private string newPlanTitle = string.Empty;
    private readonly List<TourPlanDto> myTourPlans = [];
    private readonly List<ChatRoomDto> chatRoomsForShare = [];
    private bool mapInitialized = false;
    private string? mapInitializedResourceId;
    private ResourceReviewCreateDto reviewInput = new() { Rating = 5, Content = string.Empty };
    private AttractionCreateDto editAttraction = new() { Name = string.Empty };
    private AccommodationCreateDto editAccommodation = new() { Name = string.Empty };
    private DiningCreateDto editDining = new() { Name = string.Empty };
    private FolkActivityCreateDto editFolk = new() { Name = string.Empty };
    private BeautifulVillageCreateDto editBeautifulVillage = new() { Name = string.Empty };

    private object currentEditModel => Type switch
    {
        "attractions" => editAttraction,
        "accommodations" => editAccommodation,
        "dining" => editDining,
        "folk" => editFolk,
        "beautiful-villages" => editBeautifulVillage,
        _ => editAttraction
    };

    private string CurrentImageUrl => imageUrls.Count == 0
        ? "https://dummyimage.com/900x500/dee2e6/6c757d.jpg&text=No+Image"
        : imageUrls[currentImageIndex];

    private double DisplayRating => reviewCount == 0 ? 5.0 : baseResource.AverageRating;

    private IEnumerable<ResourceReviewDto> SortedReviews
    {
        get
        {
            IEnumerable<ResourceReviewDto> query = resourceReviews;
            if (reviewFilter is >= 1 and <= 5)
            {
                query = query.Where(r => r.Rating == reviewFilter);
            }

            return reviewSort == "rating"
                ? query.OrderByDescending(r => r.Rating).ThenByDescending(r => r.CreatedAt)
                : query.OrderByDescending(r => r.CreatedAt);
        }
    }

    private void SetReviewFilter(int rating)
    {
        reviewFilter = rating;
    }

    private async Task HandleEditCoverUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isEditCoverUploading = true;
        errorMsg = null;
        successMsg = null;
        try
        {
            var uploaded = await PostService.UploadMediaWithIdAsync(file);

            if (Type == "attractions")
                editAttraction.CoverMediaId = uploaded.Id;
            else if (Type == "accommodations")
                editAccommodation.CoverMediaId = uploaded.Id;
            else if (Type == "dining")
                editDining.CoverMediaId = uploaded.Id;
            else if (Type == "folk")
                editFolk.CoverMediaId = uploaded.Id;
            else if (Type == "beautiful-villages")
                editBeautifulVillage.CoverMediaId = uploaded.Id;

            successMsg = "封面图片上传成功。";
        }
        catch (Exception ex)
        {
            errorMsg = $"封面上传失败: {ex.Message}";
        }
        finally
        {
            isEditCoverUploading = false;
        }
    }

    private async Task OpenJoinPlanPanelAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo($"/login?returnUrl=/resources/{Type}/{Id}");
            return;
        }

        newPlanTitle = $"{baseResource.Name}行程";
        myTourPlans.Clear();
        myTourPlans.AddRange(await TourPlanService.GetMyPlansAsync());
        joinPlanMode = myTourPlans.Count == 0 ? "new" : "existing";
        selectedPlanId = myTourPlans.FirstOrDefault()?.Id;
        showJoinPlanPanel = true;
    }

    private async Task OpenShareResourcePanelAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo($"/login?returnUrl=/resources/{Type}/{Id}");
            return;
        }

        currentUserId = AuthService.GetUserId();
        showShareResourcePanel = true;
        isLoadingShareRooms = true;
        shareResourceMessage = null;

        try
        {
            var rooms = await ChatService.GetMyRoomsAsync();
            chatRoomsForShare.Clear();
            chatRoomsForShare.AddRange(rooms
                .Where(r => !r.IsArchived)
                .Where(r => r.IsGroup || r.Members.Any(m => m.UserId == currentUserId && m.IsActive)));

            selectedShareRoomId = chatRoomsForShare.FirstOrDefault()?.Id;
        }
        catch (Exception ex)
        {
            chatRoomsForShare.Clear();
            selectedShareRoomId = null;
            shareResourceMessage = $"加载聊天会话失败: {ex.Message}";
        }
        finally
        {
            isLoadingShareRooms = false;
        }
    }

    private void CloseShareResourcePanel()
    {
        showShareResourcePanel = false;
        isLoadingShareRooms = false;
        isSharingResource = false;
        shareResourceMessage = null;
    }

    private async Task ShareResourceToChatAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedShareRoomId)) return;

        isSharingResource = true;
        shareResourceMessage = null;
        try
        {
            var cover = imageUrls.FirstOrDefault() ?? string.Empty;
            await ChatService.SendMessageAsync(new ChatMessageCreateDto
            {
                ChatRoomId = selectedShareRoomId,
                Type = ChatMessageType.Link,
                Content = $"SHARE_RESOURCE|{Type}|{Id}|{Uri.EscapeDataString(baseResource.Name)}|{Uri.EscapeDataString(cover)}|{DisplayRating:0.0}"
            });

            await ResourceService.TrackResourceInteractionAsync(Id, "Share", $"detail:{Type}");

            shareResourceMessage = "已分享景点。";
            showShareResourcePanel = false;
        }
        catch (Exception ex)
        {
