    private async Task LoadSidebarDataAsync()
    {
        nearbyAttractions.Clear();
        nearbyAccommodations.Clear();
        nearbyDining.Clear();
        nearbyBeautifulVillages.Clear();
        villageAttractions.Clear();
        villageAccommodations.Clear();
        villageDining.Clear();
        villageFolkActivities.Clear();

        try
        {
            if (Type == "beautiful-villages")
            {
                await LoadVillageRelatedResourcesAsync();
                return;
            }

            if (baseResource.Latitude == 0 || baseResource.Longitude == 0) return;

            var lat = baseResource.Latitude;
            var lng = baseResource.Longitude;

            var attractionsList = await ResourceService.GetAttractionsAsync();
            nearbyAttractions.AddRange(attractionsList
                .Where(x => !(Type == "attractions" && x.Id == Id))
                .Where(x => x.Latitude != 0 && x.Longitude != 0)
                .Select(x => new { Item = x, Distance = GetDistanceKm(lat, lng, x.Latitude, x.Longitude) })
                .Where(x => x.Distance <= nearbyRadiusKm)
                .OrderBy(x => x.Distance)
                .Take(5)
                .Select(x => x.Item));

            var accommodations = await ResourceService.GetAccommodationsAsync();
            nearbyAccommodations.AddRange(accommodations
                .Where(x => !(Type == "accommodations" && x.Id == Id))
                .Where(x => x.Latitude != 0 && x.Longitude != 0)
                .Select(x => new { Item = x, Distance = GetDistanceKm(lat, lng, x.Latitude, x.Longitude) })
                .Where(x => x.Distance <= nearbyRadiusKm)
                .OrderBy(x => x.Distance)
                .Take(5)
                .Select(x => x.Item));

            var diningList = await ResourceService.GetDiningAsync();
            nearbyDining.AddRange(diningList
                .Where(x => !(Type == "dining" && x.Id == Id))
                .Where(x => x.Latitude != 0 && x.Longitude != 0)
                .Select(x => new { Item = x, Distance = GetDistanceKm(lat, lng, x.Latitude, x.Longitude) })
                .Where(x => x.Distance <= nearbyRadiusKm)
                .OrderBy(x => x.Distance)
                .Take(5)
                .Select(x => x.Item));

            var villages = await ResourceService.GetBeautifulVillagesAsync();
            nearbyBeautifulVillages.AddRange(villages
                .Where(x => !(Type == "beautiful-villages" && x.Id == Id))
                .Where(x => x.Latitude != 0 && x.Longitude != 0)
                .Select(x => new { Item = x, Distance = GetDistanceKm(lat, lng, x.Latitude, x.Longitude) })
                .Where(x => x.Distance <= nearbyRadiusKm)
                .OrderBy(x => x.Distance)
                .Take(5)
                .Select(x => x.Item));
        }
        catch
        {
        }
    }

    private async Task LoadVillageRelatedResourcesAsync()
    {
        var villageTag = GetVillageTag();
        if (string.IsNullOrWhiteSpace(villageTag)) return;

        var attractions = await ResourceService.GetAttractionsAsync(1, 200);
        villageAttractions.AddRange(attractions.Where(x => HasVillageTag(x.Tags, villageTag)));

        var accommodations = await ResourceService.GetAccommodationsAsync(1, 200);
        villageAccommodations.AddRange(accommodations.Where(x => HasVillageTag(x.Tags, villageTag)));

        var dining = await ResourceService.GetDiningAsync(1, 200);
        villageDining.AddRange(dining.Where(x => HasVillageTag(x.Tags, villageTag)));

        var folk = await ResourceService.GetFolkActivitiesAsync(1, 200);
        villageFolkActivities.AddRange(folk.Where(x => HasVillageTag(x.Tags, villageTag)));
    }

    private string GetVillageTag() => $"village:{Id}";

    private static bool HasVillageTag(string? tags, string villageTag)
    {
        if (string.IsNullOrWhiteSpace(tags) || string.IsNullOrWhiteSpace(villageTag)) return false;

        return tags
            .Split([',', '，', ';', '；', '|', '/', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Any(x => string.Equals(x, villageTag, StringComparison.OrdinalIgnoreCase));
    }

    private static double GetDistanceKm(double lat1, double lng1, double lat2, double lng2)
    {
        const double earthRadiusKm = 6371d;
        static double ToRadians(double degree) => degree * Math.PI / 180d;

        var dLat = ToRadians(lat2 - lat1);
        var dLng = ToRadians(lng2 - lng1);
        var a = Math.Pow(Math.Sin(dLat / 2), 2) +
                Math.Cos(ToRadians(lat1)) * Math.Cos(ToRadians(lat2)) *
                Math.Pow(Math.Sin(dLng / 2), 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return earthRadiusKm * c;
    }

    private void BuildImageGallery()
    {
        imageUrls.Clear();
        currentImageIndex = 0;

        if (!string.IsNullOrWhiteSpace(baseResource.CoverMediaId))
        {
            var items = baseResource.CoverMediaId
                .Split([',', ';', '\n', '\r'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase);

            foreach (var item in items)
            {
                var url = GetImageUrl(item);
                if (!imageUrls.Contains(url, StringComparer.OrdinalIgnoreCase))
                {
                    imageUrls.Add(url);
                }
            }
        }

        foreach (var photo in resourcePhotos)
        {
            var url = GetImageUrl(photo.Url);
            if (!imageUrls.Contains(url, StringComparer.OrdinalIgnoreCase))
            {
                imageUrls.Add(url);
            }
        }
    }

