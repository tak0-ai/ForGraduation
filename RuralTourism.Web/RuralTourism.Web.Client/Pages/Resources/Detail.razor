@page "/resources/{type}/{id}"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject ResourceService ResourceService
@inject PostService PostService
@inject TourPlanService TourPlanService
@inject ChatService ChatService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <button class="btn btn-outline-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> 返回列表
        </button>
        @if (!isLoading && !notFound && AuthService.IsAuthenticated && AuthService.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" @onclick="BeginEdit" disabled="@isDeleting">
                    <i class="bi bi-pencil-square"></i> 修改资源
                </button>
                <button class="btn btn-danger" @onclick="DeleteResourceAsync" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    <i class="bi bi-trash"></i> 删除资源
                </button>
            </div>
        }
    </div>

    @if (errorMsg != null)
    {
        <div class="alert alert-danger mb-3">@errorMsg</div>
    }
    @if (successMsg != null)
    {
        <div class="alert alert-success mb-3">@successMsg</div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (notFound)
    {
        <div class="alert alert-warning">未找到该资源</div>
    }
    else
    {
        @if (isEditing)
        {
            <div class="card border-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">修改资源</h5>
                    <EditForm OnValidSubmit="SaveEditAsync" Model="currentEditModel">
                        <div class="row g-2">
                            @if (Type == "attractions")
                            {
                                <div class="col-md-6"><label class="form-label">名称</label><InputText class="form-control" @bind-Value="editAttraction.Name" /></div>
                                <div class="col-md-6">
                                    <label class="form-label">封面图片</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <InputFile OnChange="HandleEditCoverUpload" class="form-control" accept="image/*" />
                                        @if (isEditCoverUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(editAttraction.CoverMediaId))
                                    {
                                        <img src="@GetImageUrl(editAttraction.CoverMediaId)" class="mt-2 rounded border" style="width: 120px; height: 90px; object-fit: cover;" />
                                    }
                                </div>
                                <div class="col-md-12"><label class="form-label">描述</label><InputTextArea class="form-control" rows="2" @bind-Value="editAttraction.Description" /></div>
                                <div class="col-md-12"><label class="form-label">标签（逗号分隔）</label><InputText class="form-control" @bind-Value="editAttraction.Tags" /></div>
                                <div class="col-md-6"><label class="form-label">地址</label><InputText class="form-control" @bind-Value="editAttraction.Address" /></div>
                                <div class="col-md-3"><label class="form-label">经度</label><InputNumber class="form-control" @bind-Value="editAttraction.Longitude" /></div>
                                <div class="col-md-3"><label class="form-label">纬度</label><InputNumber class="form-control" @bind-Value="editAttraction.Latitude" /></div>
                                <div class="col-md-4"><label class="form-label">开放时间</label><InputText class="form-control" @bind-Value="editAttraction.OpeningHours" /></div>
                                <div class="col-md-4"><label class="form-label">门票价格</label><InputText class="form-control" @bind-Value="editAttraction.TicketPrice" /></div>
                            }
                            else if (Type == "accommodations")
                            {
                                <div class="col-md-6"><label class="form-label">名称</label><InputText class="form-control" @bind-Value="editAccommodation.Name" /></div>
                                <div class="col-md-6">
                                    <label class="form-label">封面图片</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <InputFile OnChange="HandleEditCoverUpload" class="form-control" accept="image/*" />
                                        @if (isEditCoverUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(editAccommodation.CoverMediaId))
                                    {
                                        <img src="@GetImageUrl(editAccommodation.CoverMediaId)" class="mt-2 rounded border" style="width: 120px; height: 90px; object-fit: cover;" />
                                    }
                                </div>
                                <div class="col-md-12"><label class="form-label">描述</label><InputTextArea class="form-control" rows="2" @bind-Value="editAccommodation.Description" /></div>
                                <div class="col-md-12"><label class="form-label">标签（逗号分隔）</label><InputText class="form-control" @bind-Value="editAccommodation.Tags" /></div>
                                <div class="col-md-6"><label class="form-label">地址</label><InputText class="form-control" @bind-Value="editAccommodation.Address" /></div>
                                <div class="col-md-3"><label class="form-label">经度</label><InputNumber class="form-control" @bind-Value="editAccommodation.Longitude" /></div>
                                <div class="col-md-3"><label class="form-label">纬度</label><InputNumber class="form-control" @bind-Value="editAccommodation.Latitude" /></div>
                                <div class="col-md-4"><label class="form-label">星级</label><InputNumber class="form-control" @bind-Value="editAccommodation.StarRating" /></div>
                                <div class="col-md-4"><label class="form-label">设施</label><InputText class="form-control" @bind-Value="editAccommodation.Amenities" /></div>
                                <div class="col-md-4"><label class="form-label">房型</label><InputText class="form-control" @bind-Value="editAccommodation.RoomTypes" /></div>
                            }
                            else if (Type == "dining")
                            {
                                <div class="col-md-6"><label class="form-label">名称</label><InputText class="form-control" @bind-Value="editDining.Name" /></div>
                                <div class="col-md-6">
                                    <label class="form-label">封面图片</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <InputFile OnChange="HandleEditCoverUpload" class="form-control" accept="image/*" />
                                        @if (isEditCoverUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(editDining.CoverMediaId))
                                    {
                                        <img src="@GetImageUrl(editDining.CoverMediaId)" class="mt-2 rounded border" style="width: 120px; height: 90px; object-fit: cover;" />
                                    }
                                </div>
                                <div class="col-md-12"><label class="form-label">描述</label><InputTextArea class="form-control" rows="2" @bind-Value="editDining.Description" /></div>
                                <div class="col-md-12"><label class="form-label">标签（逗号分隔）</label><InputText class="form-control" @bind-Value="editDining.Tags" /></div>
                                <div class="col-md-6"><label class="form-label">地址</label><InputText class="form-control" @bind-Value="editDining.Address" /></div>
                                <div class="col-md-3"><label class="form-label">经度</label><InputNumber class="form-control" @bind-Value="editDining.Longitude" /></div>
                                <div class="col-md-3"><label class="form-label">纬度</label><InputNumber class="form-control" @bind-Value="editDining.Latitude" /></div>
                                <div class="col-md-4"><label class="form-label">菜系</label><InputText class="form-control" @bind-Value="editDining.CuisineType" /></div>
                                <div class="col-md-4"><label class="form-label">人均价格</label><InputText class="form-control" @bind-Value="editDining.PriceRange" /></div>
                                <div class="col-md-4"><label class="form-label">特色菜</label><InputText class="form-control" @bind-Value="editDining.SignatureDishes" /></div>
                            }
                            else if (Type == "folk")
                            {
                                <div class="col-md-6"><label class="form-label">名称</label><InputText class="form-control" @bind-Value="editFolk.Name" /></div>
                                <div class="col-md-6">
                                    <label class="form-label">封面图片</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <InputFile OnChange="HandleEditCoverUpload" class="form-control" accept="image/*" />
                                        @if (isEditCoverUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(editFolk.CoverMediaId))
                                    {
                                        <img src="@GetImageUrl(editFolk.CoverMediaId)" class="mt-2 rounded border" style="width: 120px; height: 90px; object-fit: cover;" />
                                    }
                                </div>
                                <div class="col-md-12"><label class="form-label">描述</label><InputTextArea class="form-control" rows="2" @bind-Value="editFolk.Description" /></div>
                                <div class="col-md-12"><label class="form-label">标签（逗号分隔）</label><InputText class="form-control" @bind-Value="editFolk.Tags" /></div>
                                <div class="col-md-6"><label class="form-label">地址</label><InputText class="form-control" @bind-Value="editFolk.Address" /></div>
                                <div class="col-md-3"><label class="form-label">经度</label><InputNumber class="form-control" @bind-Value="editFolk.Longitude" /></div>
                                <div class="col-md-3"><label class="form-label">纬度</label><InputNumber class="form-control" @bind-Value="editFolk.Latitude" /></div>
                                <div class="col-md-4"><label class="form-label">活动日期</label><InputDate class="form-control" @bind-Value="editFolk.EventDate" /></div>
                                <div class="col-md-4"><label class="form-label">持续时间</label><InputText class="form-control" @bind-Value="editFolk.Duration" /></div>
                                <div class="col-md-4"><label class="form-label">主办方</label><InputText class="form-control" @bind-Value="editFolk.Organizer" /></div>
                            }
                            else if (Type == "beautiful-villages")
                            {
                                <div class="col-md-6"><label class="form-label">名称</label><InputText class="form-control" @bind-Value="editBeautifulVillage.Name" /></div>
                                <div class="col-md-6">
                                    <label class="form-label">封面图片</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <InputFile OnChange="HandleEditCoverUpload" class="form-control" accept="image/*" />
                                        @if (isEditCoverUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(editBeautifulVillage.CoverMediaId))
                                    {
                                        <img src="@GetImageUrl(editBeautifulVillage.CoverMediaId)" class="mt-2 rounded border" style="width: 120px; height: 90px; object-fit: cover;" />
                                    }
                                </div>
                                <div class="col-md-12"><label class="form-label">描述</label><InputTextArea class="form-control" rows="2" @bind-Value="editBeautifulVillage.Description" /></div>
                                <div class="col-md-12"><label class="form-label">标签（逗号分隔）</label><InputText class="form-control" @bind-Value="editBeautifulVillage.Tags" /></div>
                                <div class="col-md-6"><label class="form-label">地址</label><InputText class="form-control" @bind-Value="editBeautifulVillage.Address" /></div>
                                <div class="col-md-3"><label class="form-label">经度</label><InputNumber class="form-control" @bind-Value="editBeautifulVillage.Longitude" /></div>
                                <div class="col-md-3"><label class="form-label">纬度</label><InputNumber class="form-control" @bind-Value="editBeautifulVillage.Latitude" /></div>
                                <div class="col-md-6"><label class="form-label">村镇类型</label><InputText class="form-control" @bind-Value="editBeautifulVillage.VillageType" /></div>
                                <div class="col-md-6"><label class="form-label">著名景点或特色</label><InputText class="form-control" @bind-Value="editBeautifulVillage.FamousFor" /></div>
                            }
                            <div class="col-12 d-flex gap-2 mt-2">
                                <button class="btn btn-primary" type="submit" disabled="@isSaving">保存修改</button>
                                <button class="btn btn-outline-secondary" type="button" @onclick="CancelEdit" disabled="@isSaving">取消</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }



        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="scenic-title mb-0">@baseResource.Name</h1>
            <div class="d-flex gap-4 text-center">
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="OpenJoinPlanPanelAsync">
                    <i class="bi bi-calendar-check-fill me-1"></i> 加入行程
                </button>
                <button type="button" class="btn btn-outline-success btn-sm" @onclick="OpenShareResourcePanelAsync">
                    <i class="bi bi-share me-1"></i> 分享
                </button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-7">
                                <div class="position-relative rounded overflow-hidden border bg-light">
                                    <img src="@CurrentImageUrl" class="w-100" style="height: 320px; object-fit: contain; background-color: #f8f9fa; cursor: zoom-in;" alt="@baseResource.Name" @onclick="() => OpenGallery(currentImageIndex)" />
                                    @if (imageUrls.Count > 1)
                                    {
                                        <button class="btn btn-dark btn-sm position-absolute top-50 start-0 translate-middle-y ms-2" @onclick="PrevImage"><i class="bi bi-chevron-left"></i></button>
                                        <button class="btn btn-dark btn-sm position-absolute top-50 end-0 translate-middle-y me-2" @onclick="NextImage"><i class="bi bi-chevron-right"></i></button>
                                    }

@if (showShareResourcePanel)
{
    <div class="gallery-overlay" @onclick="CloseShareResourcePanel">
        <div class="bg-white rounded p-3" style="width:min(560px,96vw);" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">选择聊天分享景点</h6>
                <button class="btn btn-sm btn-light" @onclick="CloseShareResourcePanel"><i class="bi bi-x-lg"></i></button>
            </div>

            @if (isLoadingShareRooms)
            {
                <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
            }
            else if (chatRoomsForShare.Count == 0)
            {
                <div class="text-muted">暂无可分享的聊天会话。</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var room in chatRoomsForShare)
                    {
                        var isSelected = selectedShareRoomId == room.Id;
                        <button type="button"
                                class="list-group-item list-group-item-action d-flex align-items-center gap-2 @(isSelected ? "active" : "")"
                                @onclick="() => selectedShareRoomId = room.Id">
                            <img src="@room.GetCoverUrl()" class="rounded-circle border" style="width:34px;height:34px;object-fit:cover;" />
                            <div class="flex-grow-1 text-start">
                                <div class="fw-semibold">@room.Name</div>
                                <div class="small @(isSelected ? "text-white-50" : "text-muted")">@GetShareRoomSubText(room)</div>
                            </div>
                        </button>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(shareResourceMessage))
            {
                <div class="small text-muted mt-2">@shareResourceMessage</div>
            }

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CloseShareResourcePanel">取消</button>
                <button class="btn btn-success btn-sm" @onclick="ShareResourceToChatAsync" disabled="@(isSharingResource || chatRoomsForShare.Count == 0 || string.IsNullOrWhiteSpace(selectedShareRoomId))">
                    @if (isSharingResource)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    确认分享
                </button>
            </div>
        </div>
    </div>
}

                                </div>
                                @if (AuthService.IsAuthenticated && AuthService.IsInRole("Admin"))
                                {
                                    <div class="d-flex justify-content-between align-items-start mt-2 gap-2">
                                        <div class="d-flex gap-2 flex-wrap">
                                            @if (imageUrls.Count > 0)
                                            {
                                                @for (var i = 0; i < imageUrls.Count; i++)
                                                {
                                                    var idx = i;
                                                    <img src="@imageUrls[idx]" class="rounded border @(currentImageIndex == idx ? "border-primary border-2" : "")" style="width: 72px; height: 54px; object-fit: cover; cursor: pointer;" @onclick="() => currentImageIndex = idx" alt="thumb-@idx" />
                                                }
                                            }
                                        </div>

                                        <div class="add-photo-wrap ms-auto">
                                            <button type="button" class="btn btn-outline-primary btn-sm add-photo-btn d-flex flex-column align-items-center justify-content-center" @onclick="TriggerAddPhoto">
                                                <i class="bi bi-plus-lg"></i>
                                                <span class="small mt-1">添加图片</span>
                                            </button>
                                            <InputFile id="resource-photo-input" OnChange="HandleUserPhotoUpload" class="d-none" accept="image/*" multiple />
                                            @if (isPhotoUploading)
                                            {
                                                <div class="mt-2">
                                                    <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                                </div>
                                            }
                                        </div>


                                    </div>
                                }
                            </div>
                            <div class="col-md-5">
                                <div class="fs-2 fw-bold text-success">@DisplayRating.ToString("0.0")<span class="fs-6 text-muted"> 分</span></div>
                                <div class="text-success mb-2">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        var threshold = i - 0.5;
                                        if (DisplayRating >= i)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else if (DisplayRating >= threshold)
                                        {
                                            <i class="bi bi-star-half"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star-fill text-secondary"></i>
                                        }
                                    }
                                    <span class="text-muted ms-2">@reviewCount 条点评</span>
                                </div>
                                @if (Type != "beautiful-villages")
                                {
                                    <div class="p-2 bg-light border rounded mb-3">
                                        <div class="text-warning fs-4 fw-bold">@GetPriceText()</div>
                                    </div>
                                }
                                <div id="baiduMap" style="height: 170px; background-color: #eee; width: 100%;" class="rounded border"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <h5 class="mb-3">景点介绍</h5>
                        <p style="white-space: pre-wrap;">@baseResource.Description</p>
                        <ul class="list-unstyled mb-0 text-muted">
                            <li><strong>地址：</strong>@baseResource.Address</li>
                            @if (Type == "attractions" && attraction != null)
                            {
                                <li><strong>开放时间：</strong>@attraction.OpeningHours</li>
                                <li><strong>门票：</strong>@attraction.TicketPrice</li>
                            }
                            else if (Type == "beautiful-villages" && beautifulVillage != null)
                            {
                                <li><strong>村镇类型：</strong>@beautifulVillage.VillageType</li>
                                <li><strong>著名景点或特色：</strong>@beautifulVillage.FamousFor</li>
                            }
                        </ul>
                    </div>
                </div>
              @*   @if (AuthService.IsAuthenticated && AuthService.IsInRole("Admin"))
                {
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body">
                            @if (resourcePhotos.Count == 0)
                            {
                                <div class="text-muted">暂无用户上传照片。</div>
                            }
                            else
                            {
                                <div class="row g-2">
                                    @foreach (var p in resourcePhotos)
                                    {
                                        <div class="col-6 col-md-4 col-lg-3">
                                            <div class="position-relative">
                                                <img src="@GetImageUrl(p.Url)" class="w-100 rounded border" style="height: 110px; object-fit: cover; cursor: zoom-in;" @onclick="() => OpenGallery(imageUrls.FindIndex(x => x == GetImageUrl(p.Url)))" />
                                                @if (AuthService.IsAuthenticated && AuthService.IsInRole("Admin"))
                                                {
                                                    <button class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1" @onclick="() => DeletePhotoAsync(p.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                } *@

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="review-header mb-3">
                            <div class="review-tab active">点评</div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                            <div class="d-flex flex-wrap gap-2 small review-filter-group">
                                <button type="button" class="btn btn-sm @(reviewFilter == 0 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(0)">全部(@resourceReviews.Count)</button>
                                <button type="button" class="btn btn-sm @(reviewFilter == 5 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(5)">五星(@resourceReviews.Count(r => r.Rating == 5))</button>
                                <button type="button" class="btn btn-sm @(reviewFilter == 4 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(4)">四星(@resourceReviews.Count(r => r.Rating == 4))</button>
                                <button type="button" class="btn btn-sm @(reviewFilter == 3 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(3)">三星(@resourceReviews.Count(r => r.Rating == 3))</button>
                                <button type="button" class="btn btn-sm @(reviewFilter == 2 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(2)">二星(@resourceReviews.Count(r => r.Rating == 2))</button>
                                <button type="button" class="btn btn-sm @(reviewFilter == 1 ? "btn-success" : "btn-outline-secondary")" @onclick="() => SetReviewFilter(1)">一星(@resourceReviews.Count(r => r.Rating == 1))</button>
                            </div>
                            <InputSelect class="form-select form-select-sm" style="width: 130px;" @bind-Value="reviewSort">
                                <option value="latest">按综合排序</option>
                                <option value="rating">按评分排序</option>
                            </InputSelect>
                        </div>

                        @if (AuthService.IsAuthenticated)
                        {
                            <div class="border rounded p-3 mb-3 bg-light-subtle">
                                <div class="row g-2">
                                    <div class="col-md-3">
                                        <label class="form-label small">评分</label>
                                        <div class="d-flex align-items-center gap-1">
                                            @for (var i = 1; i <= 5; i++)
                                            {
                                                var star = i;
                                                <button type="button"
                                                        class="btn btn-link p-0 rating-star-btn"
                                                        @onclick="() => reviewInput.Rating = star"
                                                        title="@($"{star}星")">
                                                    <i class="bi bi-star-fill @(star <= reviewInput.Rating ? "text-success" : "text-secondary")"></i>
                                                </button>
                                            }
