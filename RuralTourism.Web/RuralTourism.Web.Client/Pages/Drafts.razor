@page "/posts/drafts"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject PostService PostService
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject IJSRuntime JS

<PageTitle>ІЭёеПд</PageTitle>
<div class="mt-4">

    <div class="mb-4">
        <a class="text-decoration-none" href="/posts/mine">
            <i class="bi bi-arrow-left"></i> ·ө»ШОТөДОДХВ
        </a>
    </div>


    <h3 class="mb-4">ІЭёеПд</h3>

    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">ХэФЪјУФШЦР...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger shadow-sm">
            <p>јУФШК§°Ь: @errorMessage</p>
            <div class="mt-3">
                <button class="btn btn-primary btn-sm" @onclick="LoadAsync">ЦШКФ</button>
                <a href="/login" class="btn btn-outline-primary btn-sm ms-2">ЦШРВөЗВј</a>
            </div>
        </div>
    }
    else if (posts == null || !posts.Any(p => p.Status == PostStatus.Draft))
    {
        <div class="alert alert-info">ІЭёеПдКЗҝХөДЎЈ</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var p in posts!.Where(p => p.Status == PostStatus.Draft))
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@(string.IsNullOrWhiteSpace(p.Title) ? "ОЮұкМвІЭёе" : p.Title)</h5>
                        <small class="text-muted">ЧоәуұЈҙжУЪ @GetFormattedDate(p.CreatedAt)</small>
                        @if (!string.IsNullOrWhiteSpace(p.RejectReason))
                        {
                            <div class="small text-danger mt-1">Іө»ШФӯТтЈә@p.RejectReason</div>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-secondary" href="@($"/posts/edit/{p.Id}")" target="_blank">јМРшұајӯ</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDraftAsync(p)">Йҫіэ</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PostSummaryDto>? posts;
    private bool isLoading = true;
    private string? errorMessage;

    private async Task DeleteDraftAsync(PostSummaryDto post)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"И·¶ЁТӘЙҫіэІЭёе \"{post.Title ?? "ОЮұкМв"}\" ВрЈҝ");
        if (confirmed)
        {
            try
            {
                await PostService.DeletePostAsync(post.Id);
                await LoadAsync();
            }
            catch (Exception ex)
            {
                errorMessage = $"ЙҫіэК§°Ь: {ex.Message}";
            }
        }
    }


    protected override async Task OnInitializedAsync()
    {
        if (!OperatingSystem.IsBrowser())
        {
            isLoading = true;
            return;
        }

        await InitAndLoadAsync();
    }

    private async Task InitAndLoadAsync()
    {
        try
        {
            await AuthService.InitializeAsync();
            if (AuthService.IsAuthenticated)
            {
                await LoadAsync();
            }
            else
            {
                errorMessage = "ОҙјмІвөҪУРР§өДөЗВјРЕПўЎЈЗлИ·ұЈТСөЗВјЎЈ";
                isLoading = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"ИПЦӨіхКј»ҜК§°Ь: {ex.Message}";
            isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            posts = await PostService.GetMyPostsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"»сИЎІЭёеКэҫЭК§°Ь: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetFormattedDate(DateTime date)
    {
        return date.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
