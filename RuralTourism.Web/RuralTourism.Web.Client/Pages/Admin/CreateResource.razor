@page "/admin/resources/create"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject ResourceService ResourceService
@inject PostService PostService
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject IJSRuntime JSRuntime

<PageTitle>ВјИлПзҙеЧКФҙ</PageTitle>

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary">КЦ№ӨВјИлХтҪӯПзҙеЧКФҙ</h4>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/resources")'>·ө»ШБРұн</button>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                ҪцВјИлХтҪӯПзҙеВГУОПа№ШЧКФҙЈ¬ҪЁТйУЕПИМоРҙҙеВдЎўМпФ°ЎўЕ©КВМеСйЎўПзҙеГсЛЮЎўЕ©јТІНТыЎўГсЛЧ»о¶ҜөИДЪИЭЎЈ
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else
            {
                <div class="mb-4">
                    <label class="form-label fw-bold">СЎФсПзҙеЧКФҙАаРН</label>
                    <select class="form-select w-auto" @bind="resourceType" @bind:after="OnTypeChanged">
                        <option value="attraction">Пзҙеҫ°№Ы/МпФ°№Ы№в (Attraction)</option>
                        <option value="accommodation">ПзҙеГсЛЮ/Е©ЧҜЧЎЛЮ (Accommodation)</option>
                        <option value="dining">ПзНБІНТы/Е©јТІЛ (Dining)</option>
                        <option value="folk">ГсЛЧ»о¶Ҝ/·ЗТЕМеСй (Folk Activity)</option>
                        <option value="beautiful-village">ГААцПзҙе/МШЙ«ҙеВд (Beautiful Village)</option>
                    </select>
                </div>

                <hr />

                <EditForm Model="currentModel" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label">ГыіЖ <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="commonProps.Name" required />
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label">·вГжНјЖ¬</label>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <InputFile OnChange="HandleCoverUpload" class="form-control w-auto" accept="image/*" multiple />
                                @if (isUploading)
                                {
                                    <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                }
                            </div>

                            @if (uploadedCovers.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @for (var i = 0; i < uploadedCovers.Count; i++)
                                    {
                                        var index = i;
                                        <div class="position-relative border rounded overflow-hidden" style="width: 72px; height: 72px;">
                                            <img src="@uploadedCovers[index].Url" style="width: 100%; height: 100%; object-fit: cover;" />
                                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0" style="width:20px;height:20px;line-height:1" @onclick="() => RemoveCover(index)">ЎБ</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">јт¶МГиКц</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="commonProps.Description" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">КЎКР</label>
                            <input class="form-control" value="ҪӯЛХКЎ ХтҪӯКР" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Зш/ПШ/КР</label>
                            <select class="form-select" @bind="selectedDistrict">
                                <option value="ҫ©ҝЪЗш">ҫ©ҝЪЗш</option>
                                <option value="ИуЦЭЗш">ИуЦЭЗш</option>
                                <option value="өӨНҪЗш">өӨНҪЗш</option>
                                <option value="ХтҪӯРВЗш">ХтҪӯРВЗш</option>
                                <option value="ХтҪӯёЯРВЗш">ХтҪӯёЯРВЗш</option>
                                <option value="ҫдИЭКР">ҫдИЭКР</option>
                                <option value="өӨСфКР">өӨСфКР</option>
                                <option value="СпЦРКР">СпЦРКР</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ПкПёөШЦ· (ҪЦөАЎўГЕЕЖәЕөИ)</label>
                            <InputText class="form-control" @bind-Value="detailedAddress" placeholder="АэИзЈәДіДіҪЦөА123әЕ" />
                        </div>

                        <div class="col-md-12">
                            <button type="button" class="btn btn-outline-info btn-sm mb-2" @onclick="GeocodeAddress">
                                @if (isGeocoding)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                <i class="bi bi-geo-alt"></i> ЧФ¶Ҝ»сИЎҫӯОі¶И
                            </button>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">ҫӯ¶И (Longitude)</label>
                            <InputNumber class="form-control" @bind-Value="commonProps.Longitude" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Оі¶И (Latitude)</label>
                            <InputNumber class="form-control" @bind-Value="commonProps.Latitude" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">ПзҙеұкЗ© (¶әәЕ·Цёф)</label>
                            <InputText class="form-control" @bind-Value="commonProps.Tags" />
                            <div class="form-text">ҪЁТйК№УГЈәПзҙеЎўМпФ°ЎўІЙХӘЎўЕ©јТЎўГсЛЮЎў№ЕҙеЎў·ЗТЕЎўСРС§ЎўНҪІҪЎўЖпРРөИұкЗ©ЎЈ</div>
                        </div>

                        @if (RequiresVillageSelection)
                        {
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">ЛщКфПзҙе <span class="text-danger">*</span></label>
                                <select class="form-select" @bind="selectedVillageId">
                                    <option value="">-- ЗлСЎФсПзҙе --</option>
                                    @foreach (var village in beautifulVillages)
                                    {
                                        <option value="@village.Id">@village.Name</option>
                                    }
                                </select>
                                <div class="form-text">ҫ°ЗшЎўГсЛЮәНІНТыұШРл№йКфөҪТСУРПзҙеЎЈ</div>
                            </div>
                        }
                    </div>

                    <h5 class="mt-4 mb-3 border-bottom pb-2">МШ¶ЁРЕПў</h5>
                    <div class="row g-3 mb-4">
                        @if (resourceType == "attraction")
                        {
                            <div class="col-md-4">
                                <label class="form-label">ҝӘ·ЕКұјд/ҝЙУОААКұ¶О</label>
                                <select class="form-select" @bind="attractionModel.OpeningHours">
                                    <option value="">-- ЗлСЎФсҝӘ·ЕКұјд --</option>
                                    <option value="И«Мм24РЎКұ·Е">И«Мм24РЎКұҝӘ·Е</option>
                                    <option value="08:00 - 18:00">08:00 - 18:00</option>
                                    <option value="09:00 - 17:00">09:00 - 17:00</option>
                                    <option value="08:30 - 17:30">08:30 - 17:30</option>
                                    <option value="08:00 - 17:30">08:00 - 17:30</option>
                                    <option value="07:30 - 17:00">07:30 - 17:00</option>
                                    <option value="08:00 - 21:00">08:00 - 21:00</option>
                                    <option value="08:00 - 17:00">08:00 - 17:00</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ГЕЖұ/МеСй·СУГ</label>
                                <InputText class="form-control" @bind-Value="attractionModel.TicketPrice" placeholder="Аэ: Гв·СЎў30ФӘЎўІЙХӘБнјЖ" />
                            </div>
                        }
                        else if (resourceType == "accommodation")
                        {
                            <div class="col-md-4">
                                <label class="form-label">КжКК¶ИөИј¶ (1-5)</label>
                                <InputNumber class="form-control" @bind-Value="accommodationModel.StarRating" min="1" max="5" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ЕдМЧЙиК© (¶әәЕ·Цёф)</label>
                                <InputText class="form-control" @bind-Value="accommodationModel.Amenities" placeholder="WIFI,НЈіө,ІНТы,ЙХҝҫ,ЗЧЧУ" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">·ҝРН</label>
                                <InputText class="form-control" @bind-Value="accommodationModel.RoomTypes" placeholder="ҙуҙІ·ҝ,ЗЧЧУ·ҝ,ФәВд·ҝ" />
                            </div>
                        }
                        else if (resourceType == "dining")
                        {
                            <div class="col-md-4">
                                <label class="form-label">ІНТыАаРН</label>
                                <InputText class="form-control" @bind-Value="diningModel.CuisineType" placeholder="Е©јТІЛ,ПзНБІЛ,ҪӯПК,НБІЛ" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ИЛҫщПы·С</label>
                                <InputText class="form-control" @bind-Value="diningModel.PriceRange" placeholder="Аэ: 30-80ФӘ" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ХРЕЖІЛ</label>
                                <InputText class="form-control" @bind-Value="diningModel.SignatureDishes" placeholder="Е©јТНБјҰ,әмЙХИв,КұБоКЯІЛ" />
                            </div>
                        }
                        else if (resourceType == "folk")
                        {
                            <div class="col-md-4">
                                <label class="form-label">»о¶ҜИХЖЪ</label>
                                <InputDate class="form-control" @bind-Value="folkModel.EventDate" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">іЦРшКұјд</label>
                                <InputText class="form-control" @bind-Value="folkModel.Duration" placeholder="Аэ: °лМм, 1Мм, 3Мм" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ҫЩ°м·Ҫ</label>
                                <InputText class="form-control" @bind-Value="folkModel.Organizer" />
                            </div>
                        }
                        else if (resourceType == "beautiful-village")
                        {
                            <div class="col-md-4">
                                <label class="form-label">ҙеХтАаРН</label>
                                <InputText class="form-control" @bind-Value="beautifulVillageModel.VillageType" placeholder="Аэ: АъК·№Еҙе, ЙъМ¬ҙе, МпФ°ҙе" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">ҙеЧҜМШЙ«</label>
                                <InputText class="form-control" @bind-Value="beautifulVillageModel.FamousFor" placeholder="Аэ: №ЕҪЁЦю, МШЙ«ГАКі, ІЙХӘМеСй, ПзНБОД»Ҝ" />
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success">@successMessage</div>
                    }

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                            }
                            МбҪ»ПзҙеЧКФҙ
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private static readonly string[] RuralKeywords =
    [
        "Пзҙе", "ҙе", "МпФ°", "Е©", "Е©јТ", "ІЙХӘ", "№ыФ°", "ІиФ°", "өҫМп", "ГсЛЮ", "№Еҙе", "·ЗТЕ", "ГсЛЧ", "СРС§"
    ];

    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isUploading = false;
    private bool isGeocoding = false;
    private string? errorMessage;
    private string? successMessage;

    private string resourceType = "beautiful-village";
    private string selectedDistrict = "ҫ©ҝЪЗш";
    private string detailedAddress = "";

    // Used to bind common fields easily
    private class CommonResourceProps
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Address { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string? Tags { get; set; }
        public string? CoverMediaId { get; set; }
    }

    private sealed class UploadedCover
    {
        public string Id { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }

    private CommonResourceProps commonProps = new();
    private readonly List<UploadedCover> uploadedCovers = [];
    private readonly List<BeautifulVillageDto> beautifulVillages = [];
    private string selectedVillageId = string.Empty;
    
    private AttractionCreateDto attractionModel = new() { Name = "" };
    private AccommodationCreateDto accommodationModel = new() { Name = "", StarRating = 3 };
    private DiningCreateDto diningModel = new() { Name = "" };
    private FolkActivityCreateDto folkModel = new() { Name = "", EventDate = DateTime.Now };
    private BeautifulVillageCreateDto beautifulVillageModel = new() { Name = "" };

    private object currentModel => resourceType switch
    {
        "accommodation" => accommodationModel,
        "dining" => diningModel,
        "folk" => folkModel,
        "beautiful-village" => beautifulVillageModel,
        _ => attractionModel
    };

    protected override async Task OnInitializedAsync()
    {
        if (!OperatingSystem.IsBrowser()) return;

        await AuthService.InitializeAsync();
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login?returnUrl=/admin/resources/create");
            return;
        }

        if (!AuthService.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/resources");
            return;
        }

        beautifulVillages.AddRange(await ResourceService.GetBeautifulVillagesAsync(1, 200));

        isLoading = false;
    }

    private void OnTypeChanged()
    {
        errorMessage = null;
        successMessage = null;
        if (!RequiresVillageSelection)
        {
            selectedVillageId = string.Empty;
        }
    }

    private async Task HandleCoverUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        if (files.Count == 0) return;

        isUploading = true;
        errorMessage = null;

        try
        {
            foreach (var file in files)
            {
                var result = await PostService.UploadMediaWithIdAsync(file);
                uploadedCovers.Add(new UploadedCover
                {
                    Id = result.Id,
                    Url = result.Url
                });
            }

            SyncCoverMediaIds();
        }
        catch (Exception ex)
        {
            errorMessage = $"НјЖ¬ЙПҙ«К§°Ь: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private void RemoveCover(int index)
    {
        if (index < 0 || index >= uploadedCovers.Count) return;
        uploadedCovers.RemoveAt(index);
        SyncCoverMediaIds();
    }

    private void SyncCoverMediaIds()
    {
        commonProps.CoverMediaId = uploadedCovers.Count == 0
            ? null
            : uploadedCovers[0].Id;
    }

    private class GeoResult
    {
        public double Lng { get; set; }
        public double Lat { get; set; }
    }

    private async Task GeocodeAddress()
    {
        if (string.IsNullOrWhiteSpace(detailedAddress))
        {
            errorMessage = "ЗлПИМоРҙПкПёөШЦ·";
            return;
        }

        isGeocoding = true;
        errorMessage = null;
        try
        {
            var fullAddress = $"ҪӯЛХКЎХтҪӯКР{selectedDistrict}{detailedAddress}";
            var result = await JSRuntime.InvokeAsync<GeoResult?>("getBaiduLocation", fullAddress, "ХтҪӯКР");
            if (result != null)
            {
                commonProps.Longitude = result.Lng;
                commonProps.Latitude = result.Lat;
                successMessage = "ҫӯОі¶ИҪвОціЙ№ҰЈЎ";
            }
            else
            {
                errorMessage = "ОЮ·ЁҪвОцёГөШЦ·Ј¬ЗлјмІйПкПёөШЦ·КЗ·сЧјИ·»тКЦ¶ҜКдИлҫӯОі¶ИЎЈ";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"өШЦ·ҪвОцК§°Ь: {ex.Message}";
        }
        finally
        {
            isGeocoding = false;
        }
    }

    private void SwapCommonProps()
    {
        // °у¶Ё№«№ІКфРФөҪөұЗ°јӨ»оөДДЈРН
        if (resourceType == "attraction")
        {
            attractionModel.Name = commonProps.Name;
            attractionModel.Description = commonProps.Description;
            attractionModel.Address = commonProps.Address;
            attractionModel.Latitude = commonProps.Latitude;
            attractionModel.Longitude = commonProps.Longitude;
            attractionModel.Tags = commonProps.Tags;
            attractionModel.CoverMediaId = commonProps.CoverMediaId;
        }
        else if (resourceType == "accommodation")
        {
            accommodationModel.Name = commonProps.Name;
            accommodationModel.Description = commonProps.Description;
            accommodationModel.Address = commonProps.Address;
            accommodationModel.Latitude = commonProps.Latitude;
            accommodationModel.Longitude = commonProps.Longitude;
            accommodationModel.Tags = commonProps.Tags;
            accommodationModel.CoverMediaId = commonProps.CoverMediaId;
        }
        else if (resourceType == "dining")
        {
            diningModel.Name = commonProps.Name;
            diningModel.Description = commonProps.Description;
            diningModel.Address = commonProps.Address;
            diningModel.Latitude = commonProps.Latitude;
            diningModel.Longitude = commonProps.Longitude;
            diningModel.Tags = commonProps.Tags;
            diningModel.CoverMediaId = commonProps.CoverMediaId;
        }
        else if (resourceType == "folk")
        {
            folkModel.Name = commonProps.Name;
            folkModel.Description = commonProps.Description;
            folkModel.Address = commonProps.Address;
            folkModel.Latitude = commonProps.Latitude;
            folkModel.Longitude = commonProps.Longitude;
            folkModel.Tags = commonProps.Tags;
            folkModel.CoverMediaId = commonProps.CoverMediaId;
        }
        else if (resourceType == "beautiful-village")
        {
            beautifulVillageModel.Name = commonProps.Name;
            beautifulVillageModel.Description = commonProps.Description;
            beautifulVillageModel.Address = commonProps.Address;
            beautifulVillageModel.Latitude = commonProps.Latitude;
            beautifulVillageModel.Longitude = commonProps.Longitude;
            beautifulVillageModel.Tags = commonProps.Tags;
            beautifulVillageModel.CoverMediaId = commonProps.CoverMediaId;
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(commonProps.Name))
        {
            errorMessage = "ГыіЖІ»ДЬОӘҝХ";
            return;
        }

        if (RequiresVillageSelection && string.IsNullOrWhiteSpace(selectedVillageId))
        {
            errorMessage = "ЗлПИСЎФсЛщКфПзҙеЎЈ";
            return;
        }

        commonProps.Address = $"ҪӯЛХКЎХтҪӯКР{selectedDistrict}{detailedAddress}";

        if (RequiresVillageSelection)
        {
            commonProps.Tags = MergeVillageTag(commonProps.Tags, selectedVillageId);
        }

        if (commonProps.Longitude == 0 || commonProps.Latitude == 0)
        {
            await GeocodeAddress();
            commonProps.Address = $"ҪӯЛХКЎХтҪӯКР{selectedDistrict}{detailedAddress}";
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            SwapCommonProps();

            if (resourceType == "attraction")
            {
                await ResourceService.CreateAttractionAsync(attractionModel);
            }
            else if (resourceType == "accommodation")
            {
                await ResourceService.CreateAccommodationAsync(accommodationModel);
            }
            else if (resourceType == "dining")
            {
                await ResourceService.CreateDiningAsync(diningModel);
            }
            else if (resourceType == "folk")
            {
                await ResourceService.CreateFolkActivityAsync(folkModel);
            }
            else if (resourceType == "beautiful-village")
            {
                await ResourceService.CreateBeautifulVillageAsync(beautifulVillageModel);
            }

            successMessage = "ЧКФҙМнјУіЙ№ҰЈЎҝЙТФјМРшВјИл»т·ө»ШБРұнЎЈ";
            
            // ЦШЦГұнөҘТФұгјМРшВјИл
            commonProps = new CommonResourceProps();
            uploadedCovers.Clear();
            detailedAddress = "";
            selectedDistrict = "ҫ©ҝЪЗш";
            selectedVillageId = string.Empty;
            attractionModel = new() { Name = "" };
            accommodationModel = new() { Name = "", StarRating = 3 };
            diningModel = new() { Name = "" };
            folkModel = new() { Name = "", EventDate = DateTime.Now };
            beautifulVillageModel = new() { Name = "" };
        }
        catch (Exception ex)
        {
            errorMessage = $"ВјИлК§°Ь: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool RequiresVillageSelection => resourceType is "attraction" or "accommodation" or "dining";

    private static string MergeVillageTag(string? tags, string villageId)
    {
        if (string.IsNullOrWhiteSpace(villageId)) return tags ?? string.Empty;

        var villageTag = $"village:{villageId}";
        if (string.IsNullOrWhiteSpace(tags)) return villageTag;

        var items = tags
            .Split([',', 'Ј¬', ';', 'Ј»', '|', '/', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (!items.Any(x => string.Equals(x, villageTag, StringComparison.OrdinalIgnoreCase)))
        {
            items.Add(villageTag);
        }

        return string.Join(",", items.Distinct(StringComparer.OrdinalIgnoreCase));
    }
}
