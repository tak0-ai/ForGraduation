@page "/admin/reports"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject AdminReportService AdminReportService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>№ЬАнФұұЁұн</PageTitle>

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary">ДЪИЭКэҫЭұЁұн</h4>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/resources")'>·ө»ШБРұн</button>
            </div>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            else if (report == null)
            {
                <div class="alert alert-warning">ФЭОЮұЁұнКэҫЭЎЈ</div>
            }
            else
            {
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <div class="text-muted small">МыЧУ</div>
                                <div class="fs-4 fw-bold">@report.Summary.Posts</div>
                                <div class="small text-muted">ЧЬИИ¶И @report.Summary.TotalHeat.ToString("0.0")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <div class="text-muted small">Пзҙе</div>
                                <div class="fs-4 fw-bold">@report.Summary.Villages</div>
                                <div class="small text-muted">АЫјЖдҜАА @report.Summary.TotalViews</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <div class="text-muted small">ҫ°өг</div>
                                <div class="fs-4 fw-bold">@report.Summary.Attractions</div>
                                <div class="small text-muted">АЫјЖ»Ҙ¶Ҝ @report.Summary.TotalInteractions</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <div class="text-muted small">ЧЬИИ¶И</div>
                                <div class="fs-4 fw-bold text-success">@report.Summary.TotalHeat.ToString("0.0")</div>
                                <div class="small text-muted">°ҙдҜААЎўЖАВЫЎў»Ҙ¶ҜЧЫәПНіјЖ</div>
                            </div>
                        </div>
                    </div>
                </div>

                <ul class="nav nav-pills mb-3">
                    <li class="nav-item"><button class="nav-link @(activeTab == "posts" ? "active" : "")" @onclick='() => activeTab = "posts"'>МыЧУ</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "villages" ? "active" : "")" @onclick='() => activeTab = "villages"'>Пзҙе</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "attractions" ? "active" : "")" @onclick='() => activeTab = "attractions"'>ҫ°өг</button></li>
                </ul>

                @if (activeTab == "posts")
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>ұкМв</th>
                                    <th>ЧчХЯ</th>
                                    <th>дҜАА</th>
                                    <th>ЖАВЫ</th>
                                    <th>өгФЮ</th>
                                    <th>КХІШ</th>
                                    <th>·ЦПн</th>
                                    <th>ИИ¶И</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in report.Posts)
                                {
                                    <tr>
                                        <td>
                                            <a href="/posts/@item.Id" target="_blank" class="text-decoration-none">@item.Title</a>
                                            <div class="small text-muted">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                        </td>
                                        <td>@(item.AuthorName ?? "ОҙЦӘ")</td>
                                        <td>@item.Views</td>
                                        <td>@item.Comments</td>
                                        <td>@item.Likes</td>
                                        <td>@item.Bookmarks</td>
                                        <td>@item.Shares</td>
                                        <td class="fw-semibold text-success">@item.HeatScore.ToString("0.0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (activeTab == "villages")
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Пзҙе</th>
                                    <th>дҜАА</th>
                                    <th>өгЖА</th>
                                    <th>ҙеДЪдҜАА</th>
                                    <th>ҙеДЪөгЖА</th>
                                    <th>·ЦПн</th>
                                    <th>ИИ¶И</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in report.Villages)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.Name</div>
                                            <div class="small text-muted">@item.Address</div>
                                        </td>
                                        <td>@item.Views</td>
                                        <td>@item.Reviews</td>
                                        <td>@item.ChildResourceViews</td>
                                        <td>@item.ChildResourceReviews</td>
                                        <td>@item.Shares</td>
                                        <td class="fw-semibold text-success">@item.HeatScore.ToString("0.0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>ҫ°өг</th>
                                    <th>дҜАА</th>
                                    <th>өгЖА</th>
                                    <th>·ЦПн</th>
                                    <th>ИИ¶И</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in report.Attractions)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.Name</div>
                                            <div class="small text-muted">@item.Address</div>
                                        </td>
                                        <td>@item.Views</td>
                                        <td>@item.Reviews</td>
                                        <td>@item.Shares</td>
                                        <td class="fw-semibold text-success">@item.HeatScore.ToString("0.0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private AdminReportOverviewDto? report;
    private bool isLoading = true;
    private string? errorMessage;
    private string activeTab = "posts";

    protected override async Task OnInitializedAsync()
    {
        if (!OperatingSystem.IsBrowser()) return;

        await AuthService.InitializeAsync();
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login?returnUrl=/admin/reports");
            return;
        }

        if (!AuthService.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/resources");
            return;
        }

        try
        {
            report = await AdminReportService.GetOverviewAsync(20);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
