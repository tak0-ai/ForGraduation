@page "/admin/users"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject UserService UserService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>ÓĂ»§ąÜŔí</PageTitle>

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary">ÓĂ»§ąÜŔí</h4>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/resources")'>×ĘÔ´ąÜŔí</button>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            else
            {
                <div class="alert alert-info">
                    żÉÎŞÓĂ»§ÉčÖĂ·â˝ű˝ŘÖąĘ±ĽäŁ¬·â˝űĆÚĽäÓĂ»§˝«ÎŢ·¨µÇÂĽˇŁ
                </div>

                @if (users.Count == 0)
                {
                    <div class="text-muted">ÔÝÎŢÓĂ»§ĘýľÝ</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ÓĂ»§Í·Ďń</th>
                                    <th>ÓĂ»§</th>
                                    <th>˝ÇÉ«</th>
                                    <th>×´Ě¬</th>
                                    <th style="width: 220px;">·â˝űĘ±Ľä</th>
                                    <th style="width: 220px;">˛Ů×÷</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>
                                            <img src="@(string.IsNullOrWhiteSpace(user.AvatarUrl) ? UserConstants.DefaultAvatarUrl : user.AvatarUrl)" class="rounded-circle border" style="width:44px;height:44px;object-fit:cover;" />
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@GetDisplayName(user)</div>
                                            <div class="text-muted small">@user.UserName ˇ¤ @user.UserNo ˇ¤ @user.Email</div>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="selectedRoles[user.Id]">
                                                <option value="User">ÓĂ»§</option>
                                                <option value="Admin">ąÜŔíÔ±</option>
                                            </select>
                                        </td>
                                        <td>
                                            @if (user.IsBanned)
                                            {
                                                <span class="badge bg-danger">·â˝ű</span>
                                                <div class="small text-muted mt-1">ÖÁ @user.BannedUntil?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">ŐýłŁ</span>
                                            }
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="selectedDurations[user.Id]">
                                                @foreach (var option in BanOptions)
                                                {
                                                    <option value="@option.Value">@option.Label</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2 flex-wrap">
                                                <button class="btn btn-sm btn-primary" @onclick="() => UpdateRoleAsync(user)" disabled="@isSaving">¸üĐÂ˝ÇÉ«</button>
                                                <button class="btn btn-sm btn-warning" @onclick="() => BanUserAsync(user)" disabled="@isSaving">·â˝űÓĂ»§</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => UnbanUserAsync(user)" disabled="@(isSaving || !user.IsBanned)">˝â·âÓĂ»§</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private readonly List<AdminUserDto> users = [];
    private readonly List<(string Label, string Value)> BanOptions =
    [
        ("ÓŔľĂ·â˝ű", "permanent"),
        ("1 ĐˇĘ±", "1h"),
        ("24 ĐˇĘ±", "24h"),
        ("3 Ěě", "3d"),
        ("7 Ěě", "7d"),
        ("30 Ěě", "30d")
    ];

    private readonly Dictionary<string, string> selectedDurations = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> selectedRoles = new(StringComparer.OrdinalIgnoreCase);
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!OperatingSystem.IsBrowser()) return;

        await AuthService.InitializeAsync();
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login?returnUrl=/admin/users");
            return;
        }

        if (!AuthService.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/resources");
            return;
        }

        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        isLoading = true;
        try
        {
            users.Clear();
            users.AddRange(await UserService.GetAdminUsersAsync());
            selectedDurations.Clear();
            selectedRoles.Clear();
            foreach (var user in users)
            {
                selectedDurations[user.Id] = "24h";
                selectedRoles[user.Id] = user.Role;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BanUserAsync(AdminUserDto user)
    {
        errorMessage = null;
        isSaving = true;
        try
        {
            var selected = selectedDurations.GetValueOrDefault(user.Id, "24h");
            var isPermanent = string.Equals(selected, "permanent", StringComparison.OrdinalIgnoreCase);
            var bannedUntil = isPermanent ? DateTimeOffset.UtcNow.AddYears(100) : DateTimeOffset.UtcNow.Add(ParseDuration(selected));
            var success = await UserService.BanUserAsync(user.Id, bannedUntil, isPermanent);
            if (!success)
            {
                errorMessage = "·â˝űĘ§°Ü";
                return;
            }

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UnbanUserAsync(AdminUserDto user)
    {
        errorMessage = null;
        isSaving = true;
        try
        {
            var success = await UserService.UnbanUserAsync(user.Id);
            if (!success)
            {
                errorMessage = "˝â·âĘ§°Ü";
                return;
            }

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UpdateRoleAsync(AdminUserDto user)
    {
        errorMessage = null;
        isSaving = true;
        try
        {
            var newRole = selectedRoles.GetValueOrDefault(user.Id, "User");
            if (string.Equals(newRole, user.Role, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            var success = await UserService.UpdateUserRoleAsync(user.Id, newRole);
            if (!success)
            {
                errorMessage = "ĐŢ¸ÄČ¨ĎŢĘ§°Ü";
                return;
            }

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static TimeSpan ParseDuration(string value) => value switch
    {
        "1h" => TimeSpan.FromHours(1),
        "24h" => TimeSpan.FromHours(24),
        "3d" => TimeSpan.FromDays(3),
        "7d" => TimeSpan.FromDays(7),
        "30d" => TimeSpan.FromDays(30),
        _ => TimeSpan.FromHours(24)
    };

    private static string GetDisplayName(AdminUserDto user)
        => string.IsNullOrWhiteSpace(user.Nickname) ? user.UserName : user.Nickname;
}