@page "/chat"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject ChatService ChatService
@inject AuthService AuthService
@inject UserService UserService 
@inject TourPlanService TourPlanService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>¬Ņ”—Őł</PageTitle>
<div class="container-fluid chat-container mt-3">
    <div class="row h-100 g-0 border rounded shadow-sm bg-white" style="min-height: 80vh;">
        <!-- ŃńŐžŃ–ĪŪ£®◊ů≤ŗ£© -->
        <div class="col-md-4 col-lg-3 border-end d-flex flex-column list-column">
            <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">ŌŻŌĘŃ–ĪŪ</h5>
                <div class="d-flex align-items-center">
                    <button class="btn btn-sm btn-outline-secondary rounded-circle me-2 position-relative" @onclick="ShowRequestsModal" title="Õ®÷™÷––ń">
                        <i class="bi bi-bell"></i>
                        @if (pendingRequestsCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                @pendingRequestsCount
                                <span class="visually-hidden">őī∂Ń</span>
                            </span>
                        }
                    </button>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-primary rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="javascript:void(0)" @onclick="ShowSearchModal">ľ”ļ√”—/»ļ</a></li>
                            <li><a class="dropdown-item" href="javascript:void(0)" @onclick="ShowCreateGroupModal">īīĹ®»ļŃń</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="chat-list overflow-auto flex-grow-1">
                @if (chatRooms == null)
                {
                     <div class="text-center p-3 text-muted">ľ”‘ō÷–...</div>
                }
                else if (chatRooms.Count == 0)
                {
                    <div class="text-center p-3 text-muted">‘›őřŃńŐžľ«¬ľ</div>
                }
                else
                {
                    @foreach (var room in chatRooms)
                    {
                        <div class="chat-item p-3 border-bottom @(activeRoomId == room.Id ? "active" : "")" 
                             @onclick="() => SelectRoom(room)" role="button">
                            <div class="d-flex align-items-center">
                                <img src="@room.GetCoverUrl()" class="rounded-circle me-3" width="48" height="48" style="object-fit: cover;"/>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 text-truncate">@room.Name</h6>
                                        @if (room.LastMessage != null)
                                        {
                                            @* <small class="text-muted" style="font-size: 0.75rem;">@room.LastMessage.SentAt.ToLocalTime().ToString("MM-dd HH:mm")</small>◊Ę Õ *@
                                        }
                                    </div>
                                    <p class="mb-0 text-muted text-truncate small">
                                        @(room.LastMessage?.Content ?? "‘›őřŌŻŌĘ")
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- ŃńŐžīįŅŕ£®”“≤ŗ£© -->
        <div class="@(activeRoom?.IsGroup == true ? "col-md-5 col-lg-6" : "col-md-8 col-lg-9") d-flex flex-column chat-window border-end">
            @if (activeRoom != null)
            {
                <!-- Õ∑≤Ņ–ŇŌĘ -->
                <div class="p-3 border-bottom bg-light d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <button class="btn btn-link d-md-none me-2 text-dark" @onclick="() => activeRoom = null">
                            <i class="bi bi-arrow-left"></i>
                        </button>
                        <h5 class="mb-0">@activeRoom.Name</h5>
                        @if (activeRoom.IsGroup)
                        {
                            <span class="badge bg-secondary ms-2"> (@activeRoom.Members.Count »ň)</span>
                        }
                    </div>
                    @if (activeRoom.IsGroup)
                    {
                        <div class="d-flex align-items-center">
                            @if (!activeRoom.IsArchived)
                        {
                            var myMember = activeRoom.Members.FirstOrDefault(m => m.UserId == currentUserId);
                            if (myMember != null)
                            {
                                <button class="btn btn-link text-muted me-2" title="—Ż«Žļ√”—" @onclick="ShowInviteModal">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted" type="button" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                    <ul class="dropdown-menu">
                                        @if (myMember.Role == 0 || myMember.Role == 1) // Owner or Admin
                                        {
                                            <li><a class="dropdown-item" href="javascript:void(0)" @onclick="ShowRenameModal">–řłń»ļ√Ż</a></li>
                                        }
                                        
                                        @if (myMember.Role == 0) // Owner
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" @onclick="DismissGroup">Ĺ‚…Ę»ļŃń</a></li>
                                        }
                                        else 
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" @onclick="LeaveGroup">Õň≥Ų»ļŃń</a></li>
                                        }
                                    </ul>
                                </div>
                            }
                        }
                        </div>
                    }
                    else
                    {
                        <div class="dropdown">
                            <button class="btn btn-link text-muted" type="button" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                            <ul class="dropdown-menu">
                                @if(!isFriendDeleted) 
                                {
                                    <li><a class="dropdown-item text-danger" href="javascript:void(0)" @onclick="DeleteFriend">…ĺ≥żļ√”—</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item text-primary" href="javascript:void(0)" @onclick="() => SendFriendRequest(activeRoom.Members.First(m => m.UserId != currentUserId).UserId)">ľ”ļ√”—</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                <!-- ŌŻŌĘ«Ý”Ú -->
                <div class="flex-grow-1 p-3 overflow-auto bg-light" id="message-container">
                    @foreach (var msg in messages)
                    {
                        bool isMine = msg.AuthorId == currentUserId;
                        <div class="d-flex mb-3 @(isMine ? "justify-content-end" : "justify-content-start")">
                            @if (!isMine)
                            {
                                <a href="@GetPublicProfileUrl(msg.AuthorUserNo)">
                                    <img src="@msg.GetAvatarUrl()" class="rounded-circle me-2 align-self-start" width="36" height="36" />
                                </a>
                            }
                            
                            <div class="message-bubble-wrapper d-flex flex-column @(isMine ? "align-items-end" : "align-items-start")" style="max-width: 75%;">
                                @if (!isMine && activeRoom.IsGroup)
                                {
                                    <a class="text-muted mb-1 ms-1 text-decoration-none" style="font-size: 0.75rem;" href="@GetPublicProfileUrl(msg.AuthorUserNo)">@msg.AuthorName</a>
                                }
                                <div class="message-bubble p-2 rounded-3 shadow-sm @(isMine ? "bg-primary text-white" : "bg-white text-dark")">
                                    @if (TryParseSharedPlan(msg.Content, out var sharedPlan))
                                    {
                                        <a href="@($"/tour-plans?planId={sharedPlan.Id}")" class="shared-plan-card @(isMine ? "shared-plan-card-mine" : "") text-decoration-none">
                                            <div class="fw-semibold"><i class="bi bi-map me-1"></i>@sharedPlan.Title</div>
                                            <div class="small opacity-75">∆ūĶ„£ļ@sharedPlan.StartAddress</div>
                                            <div class="small opacity-75">Õĺĺ≠Ķ„£ļ@sharedPlan.WaypointCount łŲ</div>
                                            <div class="small mt-1 text-decoration-underline">Ķ„Ľų≤ťŅī––≥Ő</div>
                                        </a>
                                    }
                                    else if (TryParseSharedPost(msg.Content, out var sharedPost))
                                    {
                                        <a href="@($"/posts/{sharedPost.Id}")" class="shared-post-card @(isMine ? "shared-post-card-mine" : "") text-decoration-none">
                                            @if (!string.IsNullOrWhiteSpace(sharedPost.CoverUrl))
                                            {
                                                <img src="@sharedPost.CoverUrl" class="shared-post-cover" />
                                            }
                                            <div class="fw-semibold"><i class="bi bi-file-earmark-richtext me-1"></i>@sharedPost.Title</div>
                                            <div class="small mt-1 text-decoration-underline">Ķ„Ľų≤ťŅīŐŻ◊”</div>
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="message-content" style="white-space: pre-wrap; word-break: break-word;">@msg.Content</div>
                                    }
                                </div>
                                <small class="text-muted mt-1 mx-1" style="font-size: 0.7rem;">@msg.SentAt.ToLocalTime().ToString("HH:mm")</small>
                            </div>

                            @if (isMine)
                            {
                                <a href="@GetPublicProfileUrl(msg.AuthorUserNo)">
                                    <img src="@msg.GetAvatarUrl()" class="rounded-circle ms-2 align-self-start" width="36" height="36" />
                                </a>
                            }
                        </div>
                    }
                </div>

                <!--  š»Ž«Ý”Ú -->
                @if (activeRoom.IsArchived)
                {
                    <div class="p-3 border-top bg-light text-center text-muted">
                        ł√»ļŃń“—Ĺ‚…Ę
                     </div>
                }
                else if (isFriendDeleted)
                {
                     <div class="p-3 border-top bg-light text-center text-muted">
                        ń„“—…ĺ≥żł√ļ√”—£¨<a href="javascript:void(0)" @onclick="() => SendFriendRequest(activeRoom.Members.First(m => m.UserId != currentUserId).UserId)">÷ō–¬ŐŪľ”</a>
                     </div>
                }
                else if (activeRoom.IsGroup && activeRoom.Members.Any(m => m.UserId == currentUserId && m.MuteUntil > DateTime.UtcNow))
                {
                     <div class="p-3 border-top bg-light text-center text-danger">
                        ńķ“—ĪĽĹŻ—‘
                     </div>
                }
                else
                {
                    <div class="p-3 border-top bg-white">
                        @if (activeRoom.IsGroup)
                        {
                            <div class="mb-2">
                                <button class="btn btn-outline-success btn-sm" @onclick="OpenSharePlanPanelAsync" disabled="@(myTourPlans.Count == 0)">
                                    <i class="bi bi-share me-1"></i>∑÷ŌŪ––≥Ő
                                </button>
                            </div>
                        }
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder=" š»ŽŌŻŌĘ..." 
                                   @bind="newMessage" @bind:event="oninput" 
                                   @onkeydown="HandleKeyDown" />
                            <button class="btn btn-primary" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessage)">
                                <i class="bi bi-send-fill"></i> ∑ĘňÕ
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted bg-light">
                    <i class="bi bi-chat-square-text display-1 mb-3 text-secondary" style="opacity: 0.2;"></i>
                    <p class="fs-5">—°‘Ů“ĽłŲŃńŐžĽÚ’ŖīīĹ®–¬∂‘Ľį</p>
                </div>
            }
        </div>

        <!-- »ļ≥…‘ĪŃ–ĪŪ -->
        @if (activeRoom?.IsGroup == true)
        {
            <div class="col-md-3 col-lg-3 d-none d-md-flex flex-column bg-light border-start">
                <div class="p-3 border-bottom">
                    @if (showMemberSearch)
                    {
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" placeholder="ň—ňų≥…‘Ī..." @bind="memberSearchQuery" @bind:event="oninput" autofocus />
                            <button class="btn btn-outline-secondary" @onclick="() => { showMemberSearch = false; memberSearchQuery = string.Empty; }"><i class="bi bi-x"></i></button>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">»ļŃń≥…‘Ī @activeRoom.Members.Count</h6>
                            <button class="btn btn-sm btn-link" @onclick="() => showMemberSearch = true"><i class="bi bi-search"></i></button>
                        </div>
                    }
                </div>
                <div class="overflow-auto flex-grow-1 p-2">
                    @{
                        var filteredMembers = string.IsNullOrWhiteSpace(memberSearchQuery) 
                            ? activeRoom.Members 
                            : activeRoom.Members.Where(m => m.UserName.Contains(memberSearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();
                    }
                    @foreach(var m in filteredMembers)
                    {
                        <div class="d-flex align-items-center p-2 member-item border-bottom" role="button" @onclick="() => OnMemberClick(m)" style="cursor: pointer;">
                            <a href="@GetPublicProfileUrl(m.UserNo)" @onclick:stopPropagation="true"><img src="@(string.IsNullOrEmpty(m.AvatarUrl) ? "https://github.com/identicons/default.png" : m.AvatarUrl)" class="rounded-circle me-2" width="32" height="32" style="object-fit:cover;"/></a>
                            <a href="@GetPublicProfileUrl(m.UserNo)" class="flex-grow-1 text-truncate text-decoration-none text-dark" @onclick:stopPropagation="true">@m.UserName</a>
                            @if(m.Role == 0) { <span class="badge bg-warning text-dark me-1">»ļ÷ų</span> }
                            @if(m.Role == 1) { <span class="badge bg-info me-1">Ļ‹ņŪ‘Ī</span> }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (showSharePlanPanel)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">—°‘ŮŌ÷”–––≥Ő∑÷ŌŪ</h5>
                    <button type="button" class="btn-close" @onclick="CloseSharePlanPanel"></button>
                </div>
                <div class="modal-body">
                    @if (myTourPlans.Count == 0)
                    {
                        <div class="text-muted">‘›őřŅ…∑÷ŌŪ––≥Ő°£</div>
                    }
                    else
                    {
                        <InputSelect class="form-select" @bind-Value="sharePlanId">
                            @foreach (var plan in myTourPlans)
                            {
                                <option value="@plan.Id">@plan.Title</option>
                            }
                        </InputSelect>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseSharePlanPanel">»°ŌŻ</button>
                    <button class="btn btn-success" @onclick="SharePlanAsync" disabled="@(myTourPlans.Count == 0 || string.IsNullOrWhiteSpace(sharePlanId))">»∑»Ō∑÷ŌŪ</button>
                </div>
            </div>
        </div>
    </div>
}

@if (activeModal == ModalType.Search)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">◊ŘļŌň—ňų</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                   <div class="input-group mb-3">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" @bind="searchQuery" @bind:event="oninput" @onkeydown="@(e => e.Key == "Enter" ? SearchAsync() : Task.CompletedTask)" placeholder=" š»Ž”√ĽßID/»ļļŇ/√Ż≥∆...">
                        <button class="btn btn-primary" @onclick="SearchAsync">ň—ňų</button>
                    </div>
                    
                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <a class="nav-link @(searchType == "All" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetSearchType("All")'>»ę≤Ņ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(searchType == "User" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetSearchType("User")'>”√Ľß</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(searchType == "Group" ? "active" : "")" href="javascript:void(0)" @onclick='() => SetSearchType("Group")'>»ļŃń</a>
                        </li>
                    </ul>

                    <div class="search-results" style="max-height: 400px; overflow-y: auto;">
                        @if (isSearching)
                        {
                            <div class="text-center py-3 text-muted">ň—ňų÷–...</div>
                        }
                        else if (searchResults != null)
                        {
                            if (searchResults.Count == 0)
                            {
                                <div class="text-center py-3 text-muted">őī’“ĶĹŌŗĻōĹŠĻŻ</div>
                            }
                            else
                            {
                                @foreach (var item in searchResults)
                                {
                                    <div class="d-flex align-items-center p-2 border-bottom">
                                        <img src="@item.GetAvatarUrl()" class="rounded-circle me-3" width="48" height="48" style="object-fit: cover;"/>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@item.Name 
                                                <span class="badge @(item.Type == "Group" ? "bg-info" : "bg-success") ms-2">@item.Type @(item.NumberId.HasValue ? $"#{item.NumberId}" : "")</span>
                                            </h6>
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                <small class="text-muted">@item.Description</small>
                                            }
                                        </div>
                                        <div>
                                            @if (item.Type == "User")
                                            {
                                                if (item.Id == currentUserId)
                                                {
                                                     <button class="btn btn-sm btn-secondary" disabled>ő“◊‘ľļ</button>
                                                }
                                                else if (item.RelationStatus == "Connected")
                                                {
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => StartChatWithUser(item.Id)">ňĹŃń</button>
                                                }
                                                else if (item.RelationStatus == "Pending")
                                                {
                                                    <button class="btn btn-sm btn-secondary" disabled>Ķ»īż—ť÷§</button>
                                                }
                                                else if (item.RelationStatus == "Inbound")
                                                {
                                                     <button class="btn btn-sm btn-primary" @onclick="ShowRequestsModal">≤ťŅī…Í«Ž</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-primary" @onclick="() => SendFriendRequest(item.Id)">ŐŪľ”ļ√”—</button>
                                                }
                                            }
                                            else
                                            {
                                                if (item.RelationStatus == "Connected" || item.IsJoined)
                                                {
                                                    <button class="btn btn-sm btn-secondary" disabled>“—ľ”»Ž</button>
                                                }
                                                else if (item.RelationStatus == "Pending")
                                                {
                                                    <button class="btn btn-sm btn-secondary" disabled>Ķ»īż—ť÷§</button>
                                                }
                                                else
                                                {
                                                     <button class="btn btn-sm btn-primary" @onclick="() => JoinGroup(item.Id)">…Í«Žľ”»Ž</button>
                                                }
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (activeModal == ModalType.Requests)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Õ®÷™÷––ń</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (myRequests == null)
                    {
                         <div class="text-center p-3 text-muted">ľ”‘ō÷–...</div>
                    }
                    else if (myRequests.Count == 0)
                    {
                         <div class="text-center p-3 text-muted">‘›őř–¬Õ®÷™</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var req in myRequests)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <img src="@req.GetAvatarUrl()" class="rounded-circle me-2" width="40" height="40" />
                                        <div>
                                            <div class="fw-bold">@req.RequesterName</div>
                                            <div class="text-muted small">
                                                @if (req.Type == ChatRequestType.Friend)
                                                {
                                                    <span>«Ž«ůŐŪľ”ń„ő™ļ√”—</span>
                                                }
                                                else
                                                {
                                                    <span>…Í«Žľ”»Ž»ļŃń <strong>@req.TargetName</strong></span>
                                                }
                                            </div>
                                            @* <small class="text-muted" style="font-size:0.75rem;">@req.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</small> ◊Ę Õ*@
                                        </div>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => HandleRequest(req, true)">Õ®Ļż</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleRequest(req, false)">ĺ‹ĺÝ</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (activeModal == ModalType.MemberAction && selectedMember != null)
{
    var myRole = activeRoom!.Members.First(m => m.UserId == currentUserId).Role;
    bool canManage = (myRole == 0) // Owner
                     || (myRole == 1 && selectedMember.Role > 1); // Admin can manage Members (2)
                     
    if (selectedMember.Role == 0) canManage = false; // Cannot manage owner
    if (myRole == 1 && selectedMember.Role == 1) canManage = false; // Admin cannot manage Admin

    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@selectedMember.UserName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body d-grid gap-2">
                    @{
                        bool isFriend = chatRooms?.Any(r => !r.IsGroup && r.Members.Any(m => m.UserId == selectedMember.UserId)) == true;
                    }
                    <button class="btn btn-outline-primary" @onclick="StartChatOrAddFriend">
                        @(isFriend ? "ňĹŃń" : "ŐŪľ”ļ√”—")
                    </button>
                    @if (canManage)
                    {
                        @if (myRole == 0 && selectedMember.Role != 0) // Only Owner can manage admins
                        {
                            if (selectedMember.Role == 1)
                            {
                                <button class="btn btn-outline-secondary" @onclick="() => SetAdminRole(false)">»°ŌŻĻ‹ņŪ‘Ī</button>
                            }
                            else
                            {
                                <button class="btn btn-outline-info" @onclick="() => SetAdminRole(true)">…Ťő™Ļ‹ņŪ‘Ī</button>
                            }
                        }
                        
                        <button class="btn btn-warning" @onclick='() => activeModal = ModalType.MuteDuration'>ĹŻ—‘</button>
