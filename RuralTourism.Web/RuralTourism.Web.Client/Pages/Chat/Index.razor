    private static bool TryParseSharedPlan(string? content, out SharedPlanPayload plan)
    {
        plan = new SharedPlanPayload();
        if (string.IsNullOrWhiteSpace(content) || !content.StartsWith("SHARE_PLAN|")) return false;
        var parts = content.Split('|', 5);
        if (parts.Length < 3) return false;

        var title = Uri.UnescapeDataString(parts[2]);
        var start = parts.Length >= 4 ? Uri.UnescapeDataString(parts[3]) : string.Empty;
        var waypointCount = 0;
        if (parts.Length >= 5)
        {
            _ = int.TryParse(parts[4], out waypointCount);
        }

        plan = new SharedPlanPayload
        {
            Id = parts[1],
            Title = title,
            StartAddress = string.IsNullOrWhiteSpace(start) ? "őī…Ť÷√" : start,
            WaypointCount = waypointCount
        };

        return true;
    }

    private static bool TryParseSharedResource(string? content, out SharedResourcePayload resource)
    {
        resource = new SharedResourcePayload();
        if (string.IsNullOrWhiteSpace(content) || !content.StartsWith("SHARE_RESOURCE|")) return false;

        var parts = content.Split('|', 6);
        if (parts.Length < 4) return false;

        double rating = 0;
        if (parts.Length >= 6)
        {
            _ = double.TryParse(parts[5], out rating);
        }

        resource = new SharedResourcePayload
        {
            Type = parts[1],
            Id = parts[2],
            Name = Uri.UnescapeDataString(parts[3]),
            CoverUrl = parts.Length >= 5 ? Uri.UnescapeDataString(parts[4]) : null,
            Rating = rating
        };

        return true;
    }

    private static bool TryParseSharedPost(string? content, out SharedPostPayload post)
    {
        post = new SharedPostPayload();
        if (string.IsNullOrWhiteSpace(content) || !content.StartsWith("SHARE_POST|")) return false;

        var parts = content.Split('|', 4);
        if (parts.Length < 3) return false;

        post = new SharedPostPayload
        {
            Id = parts[1],
            Title = Uri.UnescapeDataString(parts[2]),
            CoverUrl = parts.Length >= 4 ? Uri.UnescapeDataString(parts[3]) : null
        };

        return true;
    }

