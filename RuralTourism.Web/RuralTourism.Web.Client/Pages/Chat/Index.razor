    private void HandleIncomingMessage(ChatMessageDto msg)
    {
        if (msg.ChatRoomId == activeRoomId)
        {
            // »ÁĻŻŌŻŌĘ≤Ľ‘ŕŃ–ĪŪ÷–£®»•÷ōľž≤ť£©
            if (!messages.Any(m => m.Id == msg.Id))
            {
                messages.Add(msg);
                InvokeAsync(StateHasChanged);
                // ĻŲ∂ĮĶĹĶ◊≤Ņ
            }
        }
        
        // łŁ–¬∑ŅľšŃ–ĪŪ‘§ņņ
        var room = chatRooms?.FirstOrDefault(r => r.Id == msg.ChatRoomId);
        if (room != null)
        {
            room.LastMessage = msg;
            // “∆ĶĹ∂•≤Ņ
            chatRooms?.Remove(room);
            chatRooms?.Insert(0, room);
            InvokeAsync(StateHasChanged);
        }
    }

