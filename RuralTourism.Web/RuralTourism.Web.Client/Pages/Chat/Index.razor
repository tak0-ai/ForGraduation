        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        isSearching = true;
        try
        {
            searchResults = await ChatService.SearchAsync(searchQuery, searchType);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex.Message}");
            searchResults = new();
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task StartChatWithUser(string userId)
    {
        try
        {
            var roomId = await ChatService.Create1on1ChatAsync(userId);
            CloseModal();
            await LoadRooms();
            var room = chatRooms?.FirstOrDefault(r => r.Id == roomId);
            if (room != null) await SelectRoom(room);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task JoinGroup(string groupId)
    {
        try
        {
            await ChatService.JoinGroupAsync(groupId);
            var item = searchResults?.FirstOrDefault(r => r.Id == groupId);
            if (item != null) item.RelationStatus = "Pending";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Join error: {ex.Message}");
        }
    }

    private void ToggleFriendSelection(string userId, bool isSelected)
    {
        if (isSelected) selectedFriendIds.Add(userId);
        else selectedFriendIds.Remove(userId);
    }

    private async Task CreateGroupChat()
    {
        if (selectedFriendIds.Count == 0) return;

        try
        {
            // Generate name: Me (implied) + first 2 friends
            var selectedFriends = myFriends!.Where(f => selectedFriendIds.Contains(f.Id)).ToList();
            var names = new List<string> { "ő“" }; 
            names.AddRange(selectedFriends.Take(2).Select(f => f.Nickname ?? f.UserName));
            
            string groupName = string.Join("°Ę", names);
            if (selectedFriends.Count > 2) groupName += "...";

            // Add current user to list? Backend CreateRoom logic:
            // "IsGroup=true ... room.Members.Add(Owner) ... foreach memberIds Add(Member)"
            // So we just pass friend IDs.

            var room = await ChatService.CreateGroupChatAsync(groupName, selectedFriendIds.ToList());
            
            CloseModal();
            //  ÷∂ĮĹę–¬∑Ņľš≤Ś»ŽĶĹŃ–ĪŪ∂Ý≤Ľ»ęŃŅňĘ–¬£¨’‚—ýŅ…“‘ņŻ”√ļů∂ň∑ĶĽōĶńÕÍ’Ż żĺ›
            if (room != null) 
            {
               chatRooms ??= new List<ChatRoomDto>();
               chatRooms.Insert(0, room);
               await SelectRoom(room);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Create group error: {ex.Message}");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
             await SendMessage();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (activeRoomId != null)
        {
            await ChatService.LeaveRoomAsync(activeRoomId);
        }
        ChatService.OnMessageReceived -= HandleIncomingMessage;
        await ChatService.DisposeAsync();
    }

    private static string GetPublicProfileUrl(string? userNo)
    {
        return string.IsNullOrWhiteSpace(userNo) ? "#" : $"/u/{userNo}";
    }
