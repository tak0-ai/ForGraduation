@page "/posts/mine"
@rendermode InteractiveWebAssembly
@using RuralTourism.Web.Client.Models
@using RuralTourism.Web.Client.Services
@inject PostService PostService
@inject NavigationManager Navigation
@inject AuthService AuthService


<PageTitle>ЮвЕФгЮМЧ</PageTitle>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">гЮМЧ</h3>
    <a href="/posts/drafts" target="_blank" class="btn btn-outline-secondary">
        <i class="bi bi-file-earmark-text me-1"></i> ВнИхЯф
    </a>
</div>


@if (isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">е§дкМгдижа...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger shadow-sm">
        <p>МгдиЪЇАм: @errorMessage</p>
        <div class="mt-3">
            <button class="btn btn-primary btn-sm" @onclick="LoadAsync">жиЪд</button>
            <a href="/login" class="btn btn-outline-primary btn-sm ms-2">жиаТЕЧТМ</a>
        </div>
    </div>
}
else if (posts == null || !posts.Any(p => p.Status == PostStatus.Published || p.Status == PostStatus.Private || p.Status == PostStatus.PendingReview))
{
    <div class="alert alert-info">ФуЛЙУЛгаЙЋПЊЁЂвўЫНЛђД§ЩѓКЫЕФЮФеТЃЌ<a href="/posts/edit" target="_blank">СЂМДДДНЈ</a></div>
}

else
{
    <div class="list-group">
        @foreach (var p in posts!.Where(p => p.Status == PostStatus.Published || p.Status == PostStatus.Private || p.Status == PostStatus.PendingReview))
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1">
                        @p.Title
                        @if (p.Status == PostStatus.Private)
                        {
                            <span class="badge bg-secondary ms-2" title="НіздМКПЩМћ"><i class="bi bi-lock-fill"></i> НіздМКПЩМћ</span>
                        }
                        else if (p.Status == PostStatus.PendingReview)
                        {
                            <span class="badge bg-warning text-dark ms-2" title="ЕШД§ЙмРэдБЩѓКЫ">Д§ЩѓКЫ</span>
                        }
                    </h5>
                    <small class="text-muted">ЗЂВМгк @GetPublicationDate(p)</small>
                    @if (p.Status == PostStatus.Draft && !string.IsNullOrWhiteSpace(p.RejectReason))
                    {
                        <div class="small text-danger mt-1">ВЕЛид­вђЃК@p.RejectReason</div>
                    }
                </div>
                <div class="d-flex gap-2">

                    <a class="btn btn-sm btn-outline-primary" href="@($"/posts/{p.Id}")" target="_blank">ВщПД</a>
                    @if (p.Status == PostStatus.PendingReview)
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button" disabled title="ЬћзгЩѓКЫжаЃЌднВЛПЩБрМ­">БрМ­</button>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@($"/posts/edit/{p.Id}")" target="_blank">БрМ­</a>
                    }
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(p)">ЩОГ§</button>
                </div>

            </div>
        }
    </div>
}

@if (postToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center">
                <div class="modal-header border-0">
                    <h5 class="modal-title w-100 fw-bold">ЙмРэЮФеТ</h5>
                    <button type="button" class="btn-close" @onclick="() => postToDelete = null"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="text-muted">ЮФеТЃК<strong>@postToDelete.Title</strong></p>
                    <p>ЧыбЁдёФњвЊжДааЕФВйзїЃК</p>
                </div>
                <div class="modal-footer border-0 justify-content-center flex-column gap-2 pb-4">
                    <button type="button" class="btn btn-outline-danger w-75" @onclick="DeletePostConfirmedAsync">ГЙЕзЩОГ§</button>
                    @if (postToDelete?.Status == PostStatus.Published)
                    {
                        <button type="button" class="btn btn-outline-warning w-75" @onclick="SetToPrivateAsync">ЩшЮЊНіздМКПЩМћ</button>
                    }
                    else if (postToDelete?.Status == PostStatus.Private)
                    {
                        <button type="button" class="btn btn-outline-success w-75" @onclick="SetToPublicAsync">ЩшЮЊЙЋПЊПЩМћ</button>
                    }
                    <button type="button" class="btn btn-link text-secondary w-75 mt-2" @onclick="() => postToDelete = null">ШЁЯћ</button>
                </div>

            </div>
        </div>
    </div>
}


@code {

    private List<PostSummaryDto>? posts;
    private bool isLoading = true;
    private string? errorMessage;
    private PostSummaryDto? postToDelete;

    private void ConfirmDelete(PostSummaryDto post)
    {
        postToDelete = post;
    }

    private async Task DeletePostConfirmedAsync()
    {
        if (postToDelete == null) return;
        try
        {
            await PostService.DeletePostAsync(postToDelete.Id);
            postToDelete = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"ЩОГ§ЪЇАм: {ex.Message}";
        }
    }

    private async Task SetToPrivateAsync()
    {
        if (postToDelete == null) return;
        try
        {
            await PostService.SetPostStatusAsync(postToDelete.Id, PostStatus.Private);
            postToDelete = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"ВйзїЪЇАм: {ex.Message}";
        }
    }

    private async Task SetToPublicAsync()
    {
        if (postToDelete == null) return;
        try
        {
            await PostService.SetPostStatusAsync(postToDelete.Id, PostStatus.Published);
            postToDelete = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"ВйзїЪЇАм: {ex.Message}";
        }
    }



    protected override async Task OnInitializedAsync()
    {
        // ЗўЮёЦїдЄфжШОЪБВЛМгдиЪ§ОнЃЌгЩ WASM дЫааЪБНгЙм
        if (!OperatingSystem.IsBrowser())
        {
            isLoading = true;
            return;
        }

        await InitAndLoadAsync();
    }

    private async Task InitAndLoadAsync()
    {
        try
        {
            await AuthService.InitializeAsync();
            if (AuthService.IsAuthenticated)
            {
                await LoadAsync();
            }
            else
            {
                errorMessage = "ЮДМьВтЕНгааЇЕФЕЧТМаХЯЂЁЃЧыШЗБЃвбЕЧТМЁЃ";
                isLoading = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"ШЯжЄГѕЪМЛЏЪЇАм: {ex.Message}";
            isLoading = false;
        }
    }

    private async Task LoadAsync()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            posts = await PostService.GetMyPostsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"ЛёШЁЮФеТЪ§ОнЪЇАм: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPublicationDate(PostSummaryDto post)
    {
        var date = post.PublishedAt ?? post.CreatedAt;
        return date.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}

