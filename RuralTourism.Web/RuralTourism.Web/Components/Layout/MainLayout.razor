@inherits LayoutComponentBase
@using RuralTourism.Web.Client.Components

<div class="page" style="display:flex;flex-direction:column;min-height:100vh;">
    <header style="position:sticky;top:0;z-index:1000;background-color:var(--bs-body-bg);">
        <ClientNavMenu @rendermode="InteractiveWebAssembly" />
    </header>

    <main class="flex-grow-1">
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>


